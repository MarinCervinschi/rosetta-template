---
interface Props {
	method: 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';
	path: string;
	description?: string;
	schemaLabel?: string;
	schemaHref?: string;
}

const { method, path, description, schemaLabel, schemaHref } = Astro.props;
const methodClass = `rosetta-apiref__method--${method.toLowerCase()}`;
---

<div class="rosetta-apiref">
	<div class="rosetta-apiref__head">
		<span class={`rosetta-apiref__method ${methodClass}`}>{method}</span>
		<code class="rosetta-apiref__path">{path}</code>
	</div>
	{description && <p class="rosetta-apiref__desc">{description}</p>}
	{
		schemaLabel && (
			<p class="rosetta-apiref__schema">
				<span class="rosetta-apiref__schema-label">Schema:</span>{' '}
				{schemaHref ? (
					<a href={schemaHref} class="rosetta-apiref__schema-link">
						{schemaLabel}
					</a>
				) : (
					<code>{schemaLabel}</code>
				)}
			</p>
		)
	}
	<div class="rosetta-apiref__body"><slot /></div>
</div>

<style>
	.rosetta-apiref {
		border: 1px solid var(--sl-color-hairline);
		border-radius: var(--rosetta-radius-card);
		padding: var(--rosetta-space-4) var(--rosetta-space-6);
		margin-block: var(--rosetta-space-6);
		background: var(--sl-color-bg-sidebar);
	}

	.rosetta-apiref__head {
		display: flex;
		align-items: center;
		gap: var(--rosetta-space-3);
		flex-wrap: wrap;
	}

	.rosetta-apiref__method {
		display: inline-flex;
		align-items: center;
		height: 22px;
		padding: 0 var(--rosetta-space-3);
		border-radius: var(--rosetta-radius-pill);
		font-family: var(--sl-font);
		font-size: var(--rosetta-text-xs);
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: white;
	}

	.rosetta-apiref__method--get {
		background: var(--rosetta-method-get);
	}
	.rosetta-apiref__method--post {
		background: var(--rosetta-method-post);
	}
	.rosetta-apiref__method--put {
		background: var(--rosetta-method-put);
	}
	.rosetta-apiref__method--patch {
		background: var(--rosetta-method-patch);
	}
	.rosetta-apiref__method--delete {
		background: var(--rosetta-method-delete);
	}

	.rosetta-apiref__path {
		font-family: var(--sl-font-mono);
		font-size: var(--rosetta-text-sm);
		color: var(--sl-color-text);
		background: transparent;
		padding: 0;
	}

	.rosetta-apiref__desc {
		margin: var(--rosetta-space-3) 0 0;
		color: var(--sl-color-gray-2);
		line-height: 1.5;
	}

	.rosetta-apiref__schema {
		margin: var(--rosetta-space-2) 0 0;
		font-size: var(--rosetta-text-sm);
		color: var(--sl-color-gray-3);
	}

	.rosetta-apiref__schema-label {
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-size: var(--rosetta-text-xs);
		font-weight: 500;
	}

	.rosetta-apiref__schema-link {
		color: var(--sl-color-text-accent);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color var(--rosetta-duration) var(--rosetta-ease-out);
	}

	.rosetta-apiref__schema-link:hover {
		border-bottom-color: var(--sl-color-accent);
	}

	.rosetta-apiref__body:empty {
		display: none;
	}

	.rosetta-apiref__body:not(:empty) {
		margin-top: var(--rosetta-space-3);
	}
</style>
