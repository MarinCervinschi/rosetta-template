---
// Fetches the raw-Markdown twin of the current page and writes it to
// the clipboard. Works against the /<slug>.md endpoints emitted by the
// llms-txt integration (Phase 5). Before that integration is wired,
// clicking the button will show "copy failed" — the correct signal that
// the endpoint is missing rather than silently doing nothing.

const pathname = Astro.url.pathname.replace(/\/$/, '');
const mdUrl = pathname === '' ? '/index.md' : `${pathname}.md`;
---

<button type="button" class="rosetta-copy-md" data-md-url={mdUrl}>
	<svg
		class="rosetta-copy-md__icon rosetta-copy-md__icon--default"
		width="14"
		height="14"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
		<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
	</svg>
	<svg
		class="rosetta-copy-md__icon rosetta-copy-md__icon--success"
		width="14"
		height="14"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2.5"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<polyline points="20 6 9 17 4 12" />
	</svg>
	<span class="rosetta-copy-md__label">copy as md</span>
</button>

<div
	class="rosetta-toast"
	role="status"
	aria-live="polite"
	data-rosetta-toast
></div>

<script>
	const RESET_AFTER_MS = 1500;
	const TOAST_VISIBLE_MS = 1800;

	let toastTimer: ReturnType<typeof setTimeout> | undefined;

	function showToast(message: string, variant: 'success' | 'error') {
		const toast = document.querySelector<HTMLElement>('[data-rosetta-toast]');
		if (!toast) return;
		const iconSuccess =
			'<svg class="rosetta-toast__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
		const iconError =
			'<svg class="rosetta-toast__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';
		toast.innerHTML = `${variant === 'success' ? iconSuccess : iconError}<span>${message}</span>`;
		toast.dataset.variant = variant;
		toast.dataset.visible = 'true';
		if (toastTimer) clearTimeout(toastTimer);
		toastTimer = setTimeout(() => {
			toast.dataset.visible = 'false';
		}, TOAST_VISIBLE_MS);
	}

	function bind() {
		for (const btn of document.querySelectorAll<HTMLButtonElement>(
			'.rosetta-copy-md',
		)) {
			if (btn.dataset.bound) continue;
			btn.dataset.bound = '1';
			btn.addEventListener('click', async () => {
				const url = btn.dataset.mdUrl;
				const label = btn.querySelector<HTMLElement>(
					'.rosetta-copy-md__label',
				);
				if (!url || !label) return;
				const original = label.textContent;
				try {
					const res = await fetch(url);
					if (!res.ok) throw new Error(`HTTP ${res.status}`);
					const text = await res.text();
					await navigator.clipboard.writeText(text);
					btn.dataset.state = 'success';
					label.textContent = 'copied';
					showToast('Markdown copied to clipboard', 'success');
				} catch (err) {
					console.error('[rosetta-copy-md]', err);
					btn.dataset.state = 'error';
					label.textContent = 'copy failed';
					showToast('Copy failed — open the console for details', 'error');
				}
				setTimeout(() => {
					btn.dataset.state = '';
					label.textContent = original;
				}, RESET_AFTER_MS);
			});
		}
	}

	bind();
	document.addEventListener('astro:page-load', bind);
</script>

<style>
	.rosetta-copy-md {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		height: 32px;
		padding: 0 0.7rem;
		border: 1px solid var(--sl-color-hairline);
		border-radius: var(--rosetta-radius);
		background: transparent;
		color: var(--sl-color-text);
		font-family: var(--sl-font);
		font-size: var(--rosetta-text-xs);
		font-weight: 500;
		letter-spacing: 0.06em;
		text-transform: lowercase;
		cursor: pointer;
		transition:
			border-color var(--rosetta-duration) var(--rosetta-ease-out),
			color var(--rosetta-duration) var(--rosetta-ease-out),
			background-color var(--rosetta-duration) var(--rosetta-ease-out);
	}

	.rosetta-copy-md:hover:not(:disabled) {
		border-color: var(--sl-color-accent);
		color: var(--sl-color-text-accent);
	}

	.rosetta-copy-md[data-state='success'] {
		border-color: var(--sl-color-accent);
		color: var(--sl-color-text-accent);
	}

	.rosetta-copy-md[data-state='error'] {
		border-color: var(--rosetta-callout-stripe-danger);
		color: var(--rosetta-callout-stripe-danger);
	}

	.rosetta-copy-md__icon {
		display: inline-block;
		flex: none;
	}

	.rosetta-copy-md__icon--success {
		display: none;
	}

	.rosetta-copy-md[data-state='success'] .rosetta-copy-md__icon--default {
		display: none;
	}

	.rosetta-copy-md[data-state='success'] .rosetta-copy-md__icon--success {
		display: inline-block;
	}
</style>
