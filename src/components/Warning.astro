---
interface Props {
	type?: 'caution' | 'info' | 'danger';
	title?: string;
}

const { type = 'caution', title } = Astro.props;
---

<aside class={`rosetta-warning rosetta-warning--${type}`}>
	<svg
		class="rosetta-warning__icon"
		width="18"
		height="18"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		{
			type === 'caution' && (
				<>
					<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
					<line x1="12" y1="9" x2="12" y2="13" />
					<line x1="12" y1="17" x2="12.01" y2="17" />
				</>
			)
		}
		{
			type === 'info' && (
				<>
					<circle cx="12" cy="12" r="10" />
					<line x1="12" y1="16" x2="12" y2="12" />
					<line x1="12" y1="8" x2="12.01" y2="8" />
				</>
			)
		}
		{
			type === 'danger' && (
				<>
					<circle cx="12" cy="12" r="10" />
					<line x1="15" y1="9" x2="9" y2="15" />
					<line x1="9" y1="9" x2="15" y2="15" />
				</>
			)
		}
	</svg>
	<div class="rosetta-warning__body">
		{title && <p class="rosetta-warning__title">{title}</p>}
		<div class="rosetta-warning__content"><slot /></div>
	</div>
</aside>

<style>
	.rosetta-warning {
		display: flex;
		gap: 0.75rem;
		padding: var(--rosetta-space-4) var(--rosetta-space-6);
		margin-block: var(--rosetta-space-6);
		border-radius: var(--rosetta-radius);
		border-left-width: 3px;
		border-left-style: solid;
	}

	.rosetta-warning--caution {
		background: var(--rosetta-callout-bg-caution);
		border-left-color: var(--rosetta-callout-stripe-caution);
		color: var(--sl-color-text);
	}
	.rosetta-warning--caution .rosetta-warning__icon {
		color: var(--rosetta-callout-stripe-caution);
	}

	.rosetta-warning--info {
		background: var(--rosetta-callout-bg-info);
		border-left-color: var(--rosetta-callout-stripe-info);
		color: var(--sl-color-text);
	}
	.rosetta-warning--info .rosetta-warning__icon {
		color: var(--rosetta-callout-stripe-info);
	}

	.rosetta-warning--danger {
		background: var(--rosetta-callout-bg-danger);
		border-left-color: var(--rosetta-callout-stripe-danger);
		color: var(--sl-color-text);
	}
	.rosetta-warning--danger .rosetta-warning__icon {
		color: var(--rosetta-callout-stripe-danger);
	}

	.rosetta-warning__icon {
		flex: none;
		margin-top: 0.2rem;
	}

	.rosetta-warning__body {
		flex: 1;
		min-width: 0;
	}

	.rosetta-warning__title {
		font-family: var(--rosetta-font-heading);
		font-weight: 500;
		font-size: var(--rosetta-text-lg);
		margin: 0 0 var(--rosetta-space-2);
		color: var(--sl-color-text);
	}

	.rosetta-warning__content :last-child {
		margin-bottom: 0;
	}

	.rosetta-warning__content :first-child {
		margin-top: 0;
	}
</style>
