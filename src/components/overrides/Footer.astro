---
import Default from '@astrojs/starlight/components/Footer.astro';
import rosettaConfig from '../../rosetta.config.json' with { type: 'json' };

const showCredit = rosettaConfig.showTemplateCredit !== false;
---

<Default><slot /></Default>

{showCredit && (
	<a
		class="rosetta-credit"
		href="https://github.com/MarinCervinschi/rosetta-template"
	>
		<svg
			width="14"
			height="14"
			viewBox="0 0 24 24"
			fill="currentColor"
			aria-hidden="true"
		>
			<path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.31-5.47-1.34-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6.02 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.62-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3" />
		</svg>
		Built with rosetta-template
	</a>
)}

<style>
	.rosetta-credit {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.4em;
		margin: var(--rosetta-space-4) auto var(--rosetta-space-2);
		font-family: var(--sl-font);
		font-size: var(--rosetta-text-xs);
		text-decoration: none;
		color: var(--sl-color-gray-3);
		text-align: center;
		transition: color var(--rosetta-duration) var(--rosetta-ease-out);
	}

	.rosetta-credit:hover {
		color: var(--sl-color-text-accent);
	}
</style>
